---
/**
 * Header.astro
 * currentPage: 'home' | 'calculator' | 'intake'
 * 현재 페이지에 따라 내부 앵커 링크 prefix 처리
 */
interface Props {
  currentPage?: 'home' | 'calculator' | 'intake' | 'cases' | 'faq';
}
const { currentPage = 'home' } = Astro.props;

// 메인 페이지 내부 링크: home이면 #section, 아니면 /#section
const p = currentPage === 'home' ? '' : '/';
---

<header class="fixed w-full bg-navy-800 text-white shadow-lg z-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-20">

      <!-- 로고 -->
      <div class="flex-shrink-0 flex items-center gap-1">
        <img
          src="/images/logo.png"
          alt="세무회계본 로고"
          class="w-30 h-20"
          style="filter:brightness(0) saturate(100%) invert(77%) sepia(55%) saturate(456%) hue-rotate(359deg) brightness(92%) contrast(87%);"
        />
        <a href="/" class="text-2xl font-bold tracking-tight text-white">세무회계본</a>
      </div>

      <!-- 데스크탑 네비게이션 -->
      <nav class="hidden md:flex items-center gap-2 lg:gap-5 font-semibold flex-nowrap">
        <a href={`${p}#home`}         class="whitespace-nowrap text-xs lg:text-sm hover:text-gold-500 transition">홈</a>
        <a href={`${p}#about`}        class="whitespace-nowrap text-xs lg:text-sm hover:text-gold-500 transition">세무사 소개</a>
        <a href={`${p}#services`}     class="whitespace-nowrap text-xs lg:text-sm hover:text-gold-500 transition">주요서비스</a>
        <a href="/cases"              class="whitespace-nowrap text-xs lg:text-sm hover:text-gold-500 transition">실제 사례</a>
        <a href="/faq"                class="whitespace-nowrap text-xs lg:text-sm hover:text-gold-500 transition">자주 묻는 질문</a>
        <a href={`${p}#fee-property`} class="whitespace-nowrap text-xs lg:text-sm hover:text-gold-500 transition">요금안내</a>
        <a href={`${p}#contact`}      class="whitespace-nowrap text-xs lg:text-sm hover:text-gold-500 transition">오시는 길</a>
        <a
          href="https://blog.naver.com/taxbon1000"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-1 bg-white/10 px-2 py-1 lg:px-3 lg:py-1.5 rounded hover:bg-white/20 transition whitespace-nowrap"
        >
          <span class="bg-green-500 text-white text-[9px] lg:text-[10px] font-bold px-1 rounded">NAVER</span>
          <span class="text-xs lg:text-sm">블로그</span>
        </a>
        <a
          href="/calculator"
          class="px-2 py-1 lg:px-3 lg:py-1.5 border border-white/30 text-white/80 font-bold rounded hover:bg-white/10 transition shadow-md flex items-center gap-1 whitespace-nowrap text-xs lg:text-sm"
        >
          📊 상속세 계산
        </a>
        <a
          href="/intake"
          class="px-2 py-1 lg:px-3 lg:py-1.5 border border-gold-500 text-gold-400 font-bold rounded hover:bg-gold-500 hover:text-white transition shadow-md flex items-center gap-1 whitespace-nowrap text-xs lg:text-sm"
        >
          📋 준비서류
        </a>
        <a
          href="https://booking.naver.com/booking/6/bizes/1181095"
          target="_blank"
          rel="noopener noreferrer"
          class="px-2 py-1 lg:px-3 lg:py-1.5 bg-gold-500 text-white font-bold rounded hover:bg-gold-600 transition shadow-md flex items-center gap-1 whitespace-nowrap text-xs lg:text-sm"
        >
          <i data-lucide="calendar-check" class="w-3 h-3 lg:w-4 lg:h-4"></i> 예약
        </a>
      </nav>

      <!-- 모바일 햄버거 -->
      <div class="md:hidden flex items-center">
        <button id="mobile-menu-btn" class="text-white hover:text-gold-500 focus:outline-none">
          <i data-lucide="menu" class="w-8 h-8"></i>
        </button>
      </div>
    </div>
  </div>

  <!-- 모바일 드롭다운 -->
  <div id="mobile-menu" class="hidden md:hidden bg-navy-900 border-t border-navy-800">
    <div class="px-4 pt-4 pb-6 space-y-2">
      <a href={`${p}#home`}    class="block py-2 text-gray-300 hover:text-gold-500">홈</a>
      <a href={`${p}#about`}   class="block py-2 text-gray-300 hover:text-gold-500">세무사 소개</a>
      <a href={`${p}#services`} class="block py-2 text-gray-300 hover:text-gold-500">주요서비스</a>
      <a href="/cases"   class="block py-2 text-gray-300 hover:text-gold-500">실제 사례</a>
      <a href="/faq"     class="block py-2 text-gray-300 hover:text-gold-500">자주 묻는 질문</a>
      <div class="pl-4 border-l border-gray-600 my-2">
        <span class="block py-1 text-xs text-gray-500">요금안내</span>
        <a href={`${p}#fee-property`} class="block py-2 text-gray-300 hover:text-gold-500">상속·증여·양도</a>
        <a href={`${p}#fee-business`} class="block py-2 text-gray-300 hover:text-gold-500">개인·법인</a>
      </div>
      <a href={`${p}#contact`} class="block py-2 text-gray-300 hover:text-gold-500">오시는 길</a>
      <a href="/calculator" class="block py-2 text-gray-300 hover:text-gold-500 flex items-center gap-2">
        📊 상속세 계산기
      </a>
      <a href="/intake" class="block py-2 text-gold-400 hover:text-gold-500 font-bold flex items-center gap-2">
        📋 준비서류 체크
      </a>
    </div>
  </div>
</header>

<script>
  // 모바일 메뉴 토글
  document.getElementById('mobile-menu-btn')?.addEventListener('click', () => {
    document.getElementById('mobile-menu')?.classList.toggle('hidden');
  });

  // 메뉴 안 링크 클릭 시 메뉴 자동 닫기 (같은 페이지 앵커 이동 시 메뉴가 남는 문제 해결)
  document.querySelectorAll('#mobile-menu a').forEach((a) => {
    a.addEventListener('click', () => {
      document.getElementById('mobile-menu')?.classList.add('hidden');
    });
  });
</script>
