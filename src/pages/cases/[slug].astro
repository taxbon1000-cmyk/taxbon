---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, getEntry } from 'astro:content';

export async function getStaticPaths() {
  const allCases = await getCollection('cases');
  return allCases.map((c) => ({
    params: { slug: c.slug },
    props: { entry: c },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

const typeColor: Record<string, string> = {
  '상속세':    'bg-navy-800 text-white',
  '증여세':    'bg-gold-500 text-white',
  '양도소득세': 'bg-amber-600 text-white',
  '기장':      'bg-gray-700 text-white',
  '컨설팅':    'bg-indigo-600 text-white',
};
---

<BaseLayout
  title={`${entry.data.title} | 실제 사례 | 세무회계본`}
  description={entry.data.summary}
  canonical={`https://taxbon.com/cases/${entry.slug}`}
  ogImage={entry.data.image ?? 'https://taxbon.com/images/og-image.png'}
  currentPage="home"
>
  <!-- 페이지 헤더 -->
  <section class="bg-navy-900 pt-32 pb-12">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <a href="/cases" class="inline-flex items-center gap-1.5 text-gray-400 hover:text-gold-500 text-sm mb-6 transition">
        <i data-lucide="arrow-left" class="w-4 h-4"></i> 전체 사례 보기
      </a>
      <div class="flex items-center gap-3 mb-4">
        <span class={`text-xs font-bold px-2.5 py-1 rounded-full ${typeColor[entry.data.type] ?? 'bg-gray-200 text-gray-700'}`}>
          {entry.data.type}
        </span>
        <span class="text-gray-400 text-sm">{entry.data.date}</span>
      </div>
      <h1 class="text-2xl md:text-3xl font-bold text-white leading-snug">{entry.data.title}</h1>
    </div>
  </section>

  <!-- 본문 -->
  <section class="py-12 bg-gray-50">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- 신고접수증 이미지 -->
      {entry.data.image && (
        <div class="mb-8 rounded-2xl overflow-hidden border border-gray-200 shadow-sm">
          <img
            src={entry.data.image}
            alt={`${entry.data.title} 신고접수증`}
            class="w-full object-cover"
          />
          <p class="text-center text-xs text-gray-400 py-2 bg-white">
            ※ 개인정보는 마스킹 처리되었습니다
          </p>
        </div>
      )}

      <!-- 규모 / 결과 요약 박스 -->
      {(entry.data.amount || entry.data.result) && (
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6 mb-8 flex flex-col sm:flex-row gap-4">
          {entry.data.amount && (
            <div class="flex-1">
              <p class="text-xs text-gray-400 mb-1 font-bold uppercase tracking-wide">규모</p>
              <p class="text-navy-800 font-bold">{entry.data.amount}</p>
            </div>
          )}
          {entry.data.result && (
            <div class="flex-1 sm:border-l sm:border-gray-100 sm:pl-4">
              <p class="text-xs text-gold-600 mb-1 font-bold uppercase tracking-wide">결과</p>
              <p class="text-navy-800 font-bold">{entry.data.result}</p>
            </div>
          )}
        </div>
      )}

      <!-- 마크다운 본문 -->
      <div class="prose prose-sm max-w-none
        prose-headings:text-navy-800 prose-headings:font-bold
        prose-h2:text-lg prose-h2:mt-8 prose-h2:mb-3
        prose-p:text-gray-600 prose-p:leading-relaxed
        prose-li:text-gray-600
        prose-strong:text-navy-800">
        <Content />
      </div>

      <!-- 상담 유도 -->
      <div class="mt-12 bg-navy-900 rounded-2xl p-8 text-center">
        <p class="text-white font-bold text-base mb-2">비슷한 상황이신가요?</p>
        <p class="text-gray-400 text-sm mb-6">상속세 첫 상담은 사망진단서 지참 시 무료입니다.</p>
        <div class="flex flex-col sm:flex-row gap-3 justify-center">
          <a
            href="https://booking.naver.com/booking/6/bizes/1181095"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2 bg-gold-500 hover:bg-gold-600 text-white font-bold px-8 py-4 rounded-lg transition shadow-lg"
          >
            <i data-lucide="calendar-check" class="w-5 h-5"></i>
            상담 예약하기
          </a>
          <a
            href="/"
            class="inline-flex items-center justify-center gap-2 border border-white/30 text-white hover:bg-white/10 font-bold px-8 py-4 rounded-lg transition"
          >
            <i data-lucide="home" class="w-5 h-5"></i>
            홈으로 돌아가기
          </a>
        </div>
      </div>

    </div>
  </section>
</BaseLayout>
