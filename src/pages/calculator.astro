---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="상속세 계산기 | 세무회계본"
  description="상속세 예상 세액 간편 계산기. 강남 수서역 세무회계본 천아름 세무사."
  canonical="https://taxbon.com/calculator"
  currentPage="calculator"
>

  <!-- React 18 CDN (계산기 전용) -->
  <script slot="head" crossorigin src="https://cdn.jsdelivr.net/npm/react@18/umd/react.production.min.js"></script>
  <script slot="head" crossorigin src="https://cdn.jsdelivr.net/npm/react-dom@18/umd/react-dom.production.min.js"></script>

<style>

</style>

<!-- 히어로 -->
<div class="w-full pt-20" style="background:linear-gradient(135deg,#0d1b2a 0%,#1b3d60 100%);">
    <div style="background:radial-gradient(ellipse at 60% 40%,rgba(212,175,55,.1) 0%,transparent 65%);">
        <div class="max-w-4xl mx-auto px-4 pt-10 pb-24 text-center">
            <div class="inline-block border px-4 py-1.5 rounded-full text-xs font-bold mb-4 tracking-widest uppercase"
                 style="border-color:rgba(212,175,55,.4);color:#d4af37;background:rgba(212,175,55,.1);">
                재산세제 간편 계산기
            </div>
            <h1 class="text-3xl md:text-4xl font-bold text-white mb-3">
                상속·증여·양도 <span style="color:#d4af37;">세액 계산</span>
            </h1>
            <p class="text-gray-400 text-sm md:text-base">세금 유형 선택 ➔ 정보 입력 ➔ 예상 결과 확인</p>
        </div>
    </div>
</div>

<!-- React 마운트 -->
<div id="calc-root"></div>

<!-- 전화 문의 -->
<div class="max-w-5xl mx-auto px-4 py-8 mb-8">
    <div class="bg-white rounded-2xl p-6 md:p-8 flex flex-col md:flex-row items-center justify-between shadow-sm border border-slate-200 gap-4">
        <span class="text-slate-500 font-bold text-sm">전화 문의</span>
        <div class="text-center">
            <a href="tel:02-597-5830" class="block text-3xl md:text-4xl font-extrabold text-gray-900 mb-1 hover:text-blue-700 transition">02-597-5830</a>
            <p class="text-slate-500 text-sm">평일 09:00 ~ 18:00 &nbsp;|&nbsp; 수서역 3번 출구 직결</p>
        </div>
        <a href="https://booking.naver.com/booking/6/bizes/1181095" target="_blank"
           class="px-6 py-3 bg-green-600 text-white font-bold rounded-xl hover:bg-green-700 transition shadow text-sm whitespace-nowrap">
            네이버 예약 →
        </a>
    </div>
</div>

<!-- 푸터 -->

</BaseLayout>

<!-- 기본 계산기 (index에서 이식) -->
    <!-- 계산기 팝업 -->
    <div id="calc-popup" style="
        display:none;position:fixed;bottom:6.5rem;left:2rem;z-index:9999;
        width:260px;max-width:calc(100vw - 4rem);
        background:linear-gradient(160deg,#d6d3ce 0%,#bfbcb7 100%);
        border-radius:14px;border:2px solid #888;
        box-shadow:0 16px 48px rgba(0,0,0,.55),inset 0 1px 0 rgba(255,255,255,.5);
        padding:10px;font-family:Arial,sans-serif;user-select:none;
    ">
        <!-- 디스플레이 -->
        <div style="
            background:#c8c8a8;border:3px solid #7a7a6a;border-radius:6px;
            box-shadow:inset 0 4px 10px rgba(0,0,0,.45),0 1px 0 rgba(255,255,255,.5);
            padding:4px 8px 6px;margin-bottom:8px;position:relative;overflow:hidden;
        ">
            <div id="c-sub" style="font-size:10px;color:#5a5a3a;text-align:right;min-height:14px;font-family:'Courier New',monospace;overflow:hidden;white-space:nowrap;text-overflow:ellipsis;font-weight:600;"></div>
            <div id="c-main" style="
                font-family:'Courier New',monospace;font-size:2rem;font-weight:900;
                color:#0a0a00;text-align:right;letter-spacing:1px;line-height:1.15;
                text-shadow:1px 1px 0 rgba(0,0,0,.2);
                overflow:hidden;white-space:nowrap;width:100%;display:block;
            ">0.</div>
            <div id="c-mem" style="position:absolute;left:6px;bottom:5px;font-size:10px;font-weight:900;color:#333;"></div>
        </div>
        <!-- 버튼 그리드 -->
        <div id="c-grid" style="display:grid;grid-template-columns:repeat(5,1fr);gap:3px;"></div>
    </div>

    <!-- 계산기 플로팅 토글 버튼 -->
    <button id="calc-fab" style="
        position:fixed;bottom:2rem;left:2rem;z-index:9999;
        width:68px;height:68px;border-radius:16px;
        background:#0d1b2a;border:2px solid #c9a84c;color:#fff;
        box-shadow:0 8px 30px rgba(0,0,0,.4);cursor:pointer;
        display:flex;flex-direction:column;align-items:center;justify-content:center;gap:2px;
        transition:background .2s;
    " aria-label="계산기">
        <span style="font-size:1.6rem;line-height:1;">🧮</span>
        <span style="font-size:.62rem;font-weight:800;letter-spacing:-.01em;">계산기</span>
    </button>

    <script>
    /* ──────────── 계산기 ──────────── */
    (function(){
        let cur='0', prev=null, op=null, waitNew=false, mem=0, gt=0, gtN=0;
        let kMode=false, kVal=null, kOp=null; // K 상수계산
        const dm=document.getElementById('c-main');
        const ds=document.getElementById('c-sub');
        const mm=document.getElementById('c-mem');

        function fmt(n){
            if(!isFinite(n)||isNaN(n))return'Error';
            const s=parseFloat(n.toPrecision(12)).toString();
            const[i,d]=s.split('.');
            return parseInt(i).toLocaleString('ko-KR')+(d!==undefined?'.'+d:'.');
        }

        function upd(){
            let v=cur;
            if(v!=='Error'&&!v.endsWith('.')){
                const[i,d]=v.split('.');
                v=parseInt(i).toLocaleString('ko-KR')+(d!==undefined?'.'+d:'.');
            }
            // 글자수에 따라 폰트 자동 축소 (순수 숫자 기준)
            const digits=v.replace(/[,.\-]/g,'').length;
            dm.style.fontSize=digits>11?'.95rem':digits>9?'1.15rem':digits>7?'1.45rem':digits>5?'1.7rem':'1.9rem';
            dm.textContent=v;
            mm.textContent=(mem!==0?'M ':'')+( kMode?'K':'');
        }

        function num(n){
            if(waitNew){cur='';waitNew=false;}
            if(n==='0'&&cur==='0')return;
            if(n==='00'){if(cur==='0')return;cur+='00';}
            else cur=cur==='0'?n:cur+n;
            if(cur.replace(/[.\-]/g,'').length>10)cur=cur.slice(0,-1);
            upd();
        }
        function dot(){if(waitNew){cur='0';waitNew=false;}if(!cur.includes('.'))cur+='.';upd();}

        function run(a,o,b){
            switch(o){case'+':return a+b;case'−':return a-b;case'×':return a*b;case'÷':return b===0?NaN:a/b;}
        }

        function opBtn(o){
            // 같은 연산자를 연속 두 번 → K 모드
            if(waitNew && op===o && prev!==null){
                kMode=true; kVal=prev; kOp=o;
                ds.textContent='K  '+fmt(kVal)+' '+o;
                upd(); return;
            }
            if(prev!==null&&!waitNew){
                // 이전 연산 처리
                const c=parseFloat(cur),r=run(prev,op,c);
                cur=isNaN(r)||!isFinite(r)?'Error':String(parseFloat(r.toPrecision(12)));
            }
            kMode=false; kVal=null; kOp=null;
            prev=parseFloat(cur); op=o; waitNew=true;
            ds.textContent=fmt(prev)+' '+o;
            upd();
        }

        function eq(){
            let r;
            if(kMode && kVal!==null){
                // K 상수 반복 적용
                const base=parseFloat(cur);
                r=run(base,kOp,kVal);
                ds.textContent='K  '+fmt(base)+' '+kOp+' '+fmt(kVal)+' =';
                gt+=r; gtN++;
            } else if(prev!==null&&op!==null){
                const c=parseFloat(cur);
                r=run(prev,op,c);
                ds.textContent=fmt(prev)+' '+op+' '+fmt(c)+' =';
                gt+=r; gtN++;
                // 이후 = 반복 시 같은 연산 반복하도록 K 저장
                kMode=true; kVal=c; kOp=op;
                prev=null; op=null;
            } else return;
            cur=isNaN(r)||!isFinite(r)?'Error':String(parseFloat(r.toPrecision(12)));
            waitNew=true; upd();
        }

        function ce(){cur='0';upd();}
        function ac(){cur='0';prev=null;op=null;waitNew=false;kMode=false;kVal=null;kOp=null;ds.textContent='';upd();}
        function sign(){if(cur==='0')return;cur=cur.startsWith('-')?cur.slice(1):'-'+cur;upd();}
        function pct(){const n=parseFloat(cur);cur=String(prev!==null?prev*n/100:n/100);upd();}
        function sqrt(){cur=String(Math.sqrt(parseFloat(cur)));upd();}
        function mPlus(){mem+=parseFloat(cur);upd();}
        function mMinus(){mem-=parseFloat(cur);upd();}
        function mRec(){cur=String(mem);waitNew=false;upd();}
        function mClr(){mem=0;upd();}
        function showGT(){cur=String(parseFloat(gt.toPrecision(12)));ds.textContent='GT ('+gtN+'건 합계)';waitNew=true;upd();}

        const BTNS=[
            ['%','op',pct],['√','op',sqrt],['▶','op',showGT],['GT','op',showGT],
            ['MC','mem',mClr],['MR','mem',mRec],['M−','mem',mMinus],['M+','mem',mPlus],['÷','op',()=>opBtn('÷')],
            ['+/−','op',sign],['7','num',()=>num('7')],['8','num',()=>num('8')],['9','num',()=>num('9')],['×','op',()=>opBtn('×')],
            ['C','clr',ce],['4','num',()=>num('4')],['5','num',()=>num('5')],['6','num',()=>num('6')],['−','op',()=>opBtn('−')],
            ['AC','clr',ac],['1','num',()=>num('1')],['2','num',()=>num('2')],['3','num',()=>num('3')],['+','op-tall',()=>opBtn('+')],
            ['0','num-wide',()=>num('0')],['00','num',()=>num('00')],['.','op',dot],['=','op',eq],
        ];
        const COLORS={
            num:'background:linear-gradient(180deg,#5c5c5c 0%,#3d3d3d 45%,#303030 100%);color:#fff;box-shadow:0 3px 0 #181818,0 4px 5px rgba(0,0,0,.5),inset 0 1px 0 rgba(255,255,255,.18);border:1px solid #222;text-shadow:0 1px 2px rgba(0,0,0,.6);',
            op:'background:linear-gradient(180deg,#b5ad9e 0%,#908778 45%,#7e7566 100%);color:#fff;box-shadow:0 3px 0 #524840,0 4px 5px rgba(0,0,0,.4),inset 0 1px 0 rgba(255,255,255,.25);border:1px solid #5a5040;text-shadow:0 1px 2px rgba(0,0,0,.5);',
            'op-tall':'background:linear-gradient(180deg,#b5ad9e 0%,#908778 45%,#7e7566 100%);color:#fff;box-shadow:0 3px 0 #524840,0 4px 5px rgba(0,0,0,.4),inset 0 1px 0 rgba(255,255,255,.25);border:1px solid #5a5040;text-shadow:0 1px 2px rgba(0,0,0,.5);',
            mem:'background:linear-gradient(180deg,#6e94d4 0%,#4e74b4 45%,#3e649e 100%);color:#fff;box-shadow:0 3px 0 #1e3464,0 4px 5px rgba(0,0,0,.4),inset 0 1px 0 rgba(255,255,255,.25);border:1px solid #2a4070;text-shadow:0 1px 2px rgba(0,0,0,.4);',
            clr:'background:linear-gradient(180deg,#d05878 0%,#b03458 45%,#9a2448 100%);color:#fff;box-shadow:0 3px 0 #5a1020,0 4px 5px rgba(0,0,0,.4),inset 0 1px 0 rgba(255,255,255,.2);border:1px solid #6a1828;text-shadow:0 1px 2px rgba(0,0,0,.4);',
            'num-wide':'background:linear-gradient(180deg,#5c5c5c 0%,#3d3d3d 45%,#303030 100%);color:#fff;box-shadow:0 3px 0 #181818,0 4px 5px rgba(0,0,0,.5),inset 0 1px 0 rgba(255,255,255,.18);border:1px solid #222;text-shadow:0 1px 2px rgba(0,0,0,.6);',
        };

        const grid=document.getElementById('c-grid');
        const blank=document.createElement('div');
        blank.style.cssText='background:transparent;';
        grid.appendChild(blank);

        BTNS.forEach(([label,type,fn])=>{
            const b=document.createElement('button');
            b.textContent=label;
            const isTall=type==='op-tall', isWide=type==='num-wide';
            b.style.cssText=`${COLORS[type]||COLORS.op}
                border-radius:6px;font-size:.8rem;font-weight:800;cursor:pointer;
                padding:0;display:flex;align-items:center;justify-content:center;
                height:${isTall?'82px':'38px'};
                ${isWide?'grid-column:span 2;':''}
                ${isTall?'grid-row:span 2;':''}
                -webkit-tap-highlight-color:transparent;`;
            b.addEventListener('mousedown',()=>{b.style.transform='translateY(2px)';b.style.filter='brightness(.85)';});
            b.addEventListener('mouseup',()=>{b.style.transform='';b.style.filter='';fn();});
            b.addEventListener('mouseleave',()=>{b.style.transform='';b.style.filter='';});
            b.addEventListener('touchstart',e=>{e.preventDefault();b.style.transform='translateY(2px)';b.style.filter='brightness(.85)';},{passive:false});
            b.addEventListener('touchend',e=>{e.preventDefault();b.style.transform='';b.style.filter='';fn();});
            grid.appendChild(b);
        });

        document.addEventListener('keydown',e=>{
            if(document.getElementById('calc-popup').style.display==='none')return;
            if(e.key>='0'&&e.key<='9')num(e.key);
            else if(e.key==='.')dot();
            else if(e.key==='+')opBtn('+');
            else if(e.key==='-')opBtn('−');
            else if(e.key==='*')opBtn('×');
            else if(e.key==='/'){e.preventDefault();opBtn('÷');}
            else if(e.key==='Enter'||e.key==='=')eq();
            else if(e.key==='Escape')ac();
            else if(e.key==='Backspace'){if(!waitNew)cur=cur.length>1?cur.slice(0,-1):'0';upd();}
        });
    })();

    function toggleCalc(){
        const p=document.getElementById('calc-popup');
        const show=p.style.display==='none'||p.style.display==='';
        p.style.display=show?'block':'none';
        document.getElementById('calc-fab').style.background=show?'#c9a84c':'#0d1b2a';
    }

    // FAB·팝업 클릭 바인딩 (인라인 onclick 대체)
    document.getElementById('calc-fab').addEventListener('click', function(e){
        e.stopPropagation();
        toggleCalc();
    });
    document.getElementById('calc-popup').addEventListener('click', function(e){
        e.stopPropagation();
    });

    // 외부 클릭 시 닫기
    document.addEventListener('click',function(){
        const p=document.getElementById('calc-popup');
        if(p.style.display==='block'){
            p.style.display='none';
            document.getElementById('calc-fab').style.background='#0d1b2a';
        }
    });
    </script>


<!-- 플로팅 위로가기 -->
<button id="scroll-top"
    class="fixed bottom-8 right-8 z-50 px-5 py-4 bg-navy-800 hover:bg-gold-500 text-white rounded-xl shadow-2xl transition-all duration-300 opacity-0 invisible flex items-center gap-2 border-2 border-gold-500 font-bold"
    aria-label="맨 위로">
    <span>↑</span><span>위로</span>
</button>

<script>
    if (typeof lucide !== 'undefined') lucide.createIcons();

    const st = document.getElementById('scroll-top');
    st.addEventListener('click', () => window.scrollTo({top:0,behavior:'smooth'}));
    window.addEventListener('scroll', () => {
        if (window.scrollY > 300) { st.classList.remove('opacity-0','invisible'); st.classList.add('opacity-100','visible'); }
        else { st.classList.add('opacity-0','invisible'); st.classList.remove('opacity-100','visible'); }
    });

    (function(){
        var e = ['tax','bon','@','tax','bon','.com'].join('');
        var el = document.getElementById('footer-info');
        if(el) el.innerHTML += ' | Email: <a href="mailto:'+e+'" style="color:#e8c97a">'+e+'</a>';
    })();

</script>

