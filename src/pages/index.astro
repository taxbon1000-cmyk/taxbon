<script>
        // ===== 이메일 주소 (Cloudflare 난독화 방지용 JS 구성) =====
        (function(){
            var e = ['tax','bon','@','tax','bon','.com'].join('');
            var cel = document.getElementById('contact-email-line');
            if(cel){
                cel.innerHTML = '이메일: <a href="mailto:'+e+'" class="hover:text-white transition">'+e+'</a>';
            }
            })();

        // ===== 요금 안내 탭 전환 =====
        function switchFeeTab(tab) {
            document.querySelectorAll('.fee-tab-button').forEach(btn => btn.classList.remove('active'));
            document.querySelectorAll('.fee-tab-content').forEach(content => content.classList.add('hidden'));
            document.getElementById('tab-' + tab).classList.add('active');
            document.getElementById('content-' + tab).classList.remove('hidden');
        }

        // ===== 메인 히어로 슬라이더 =====
        let heroIndex = 0;
        let heroInterval;
        const heroSlides = document.querySelectorAll('.hero-slide');
        const heroDots = document.querySelectorAll('.hero-dot');

        function switchHero(index) {
            heroSlides.forEach(s => s.classList.remove('active'));
            heroDots.forEach(d => {
                d.classList.remove('bg-gold-500', 'bg-gray-600', 'ring-2', 'ring-white');
                d.classList.add('bg-gray-500');
            });

            heroIndex = index;
            if(heroIndex >= heroSlides.length) heroIndex = 0;
            
            heroSlides[heroIndex].classList.add('active');
            heroDots[heroIndex].classList.remove('bg-gray-500');
            heroDots[heroIndex].classList.add(heroIndex === 0 ? 'bg-gold-500' : 'bg-gray-600', 'ring-2', 'ring-white');
        }

        function manualSwitchHero(index) {
            clearInterval(heroInterval);
            switchHero(index);
            startHeroAutoPlay();
        }

        function startHeroAutoPlay() {
            heroInterval = setInterval(() => {
                switchHero(heroIndex + 1);
            }, 5000);
        }
        startHeroAutoPlay();

        // ===== 전문가 선택 (이벤트 리스너 방식) =====
        var borderColors = ['border-gold-500', 'border-amber-400', 'border-indigo-400'];
        var currentExpertIndex = -1; // 현재 열려있는 패널 (없으면 -1)

        function closeExpertDetail() {
            // 모든 카드 초기화
            document.querySelectorAll('.expert-card').forEach(function(c, i) {
                c.classList.remove('shadow-lg', 'bg-gray-50', borderColors[i]);
                c.classList.add('border-gray-200', 'shadow-sm');
            });
            // 모든 상세 패널 숨김
            for (var i = 0; i < 3; i++) {
                var d = document.getElementById('expert-detail-' + i);
                if (d) d.style.display = 'none';
            }
            // wrapper 스타일 초기화
            var wrapper = document.getElementById('expert-detail-wrapper');
            if (wrapper) {
                wrapper.style.marginTop = '';
                wrapper.style.border = '';
                wrapper.style.boxShadow = '';
                wrapper.style.background = '';
            }
            currentExpertIndex = -1;
        }

        function openExpertDetail(index) {
            // 모든 카드 초기화
            document.querySelectorAll('.expert-card').forEach(function(c, i) {
                c.classList.remove('shadow-lg', 'bg-gray-50', borderColors[i]);
                c.classList.add('border-gray-200', 'shadow-sm');
            });
            // 모든 상세 패널 숨김
            for (var i = 0; i < 3; i++) {
                var d = document.getElementById('expert-detail-' + i);
                if (d) d.style.display = 'none';
            }

            // 선택 카드 강조
            var activeCard = document.getElementById('expert-card-' + index);
            if (activeCard) {
                activeCard.classList.remove('border-gray-200', 'shadow-sm');
                activeCard.classList.add(borderColors[index], 'shadow-lg', 'bg-gray-50');
            }

            // wrapper 표시
            var wrapper = document.getElementById('expert-detail-wrapper');
            if (wrapper) {
                wrapper.style.marginTop = '2rem';
                wrapper.style.border = '1px solid #f3f4f6';
                wrapper.style.boxShadow = '0 20px 25px -5px rgba(0,0,0,.1)';
                wrapper.style.background = '#fff';
            }

            // 선택 패널 표시
            var detail = document.getElementById('expert-detail-' + index);
            if (detail) detail.style.display = 'flex';

            currentExpertIndex = index;
        }

        document.querySelectorAll('.expert-card').forEach(function(card) {
            card.addEventListener('click', function() {
                var index = parseInt(this.getAttribute('data-expert'));
                if (currentExpertIndex === index) {
                    // 같은 카드 재클릭 → 닫기
                    closeExpertDetail();
                } else {
                    openExpertDetail(index);
                }
            });
        });

        // 상세 패널 닫기(X) 버튼
        document.querySelectorAll('.expert-close-btn').forEach(function(btn) {
            btn.addEventListener('click', function(e) {
                e.stopPropagation();
                closeExpertDetail();
            });
        });

        // ===== 사진 갤러리 슬라이더 =====
        let photoIndex = 0;
        const photoTotal = 5;
        const galleryTrack = document.querySelector('.gallery-track');
        const galleryDots = document.querySelectorAll('.gallery-dots button');

        function updateGallery() {
            if (galleryTrack) {
                galleryTrack.style.transform = 'translateX(-' + (photoIndex * 100) + '%)';
            }
            galleryDots.forEach((dot, i) => {
                dot.style.background = i === photoIndex ? 'rgba(255,255,255,0.9)' : 'rgba(255,255,255,0.4)';
            });
        }

        function goToPhotoSlide(index) {
            photoIndex = index;
            if (photoIndex >= photoTotal) photoIndex = 0;
            if (photoIndex < 0) photoIndex = photoTotal - 1;
            updateGallery();
        }

        function nextPhotoSlide() {
            goToPhotoSlide(photoIndex + 1);
        }

        function prevPhotoSlide() {
            goToPhotoSlide(photoIndex - 1);
        }

        updateGallery();

        // ===== 요금안내 아코디언 =====
        document.querySelectorAll('.accordion-header').forEach(button => {
            button.addEventListener('click', function() {
                const contentId = this.getAttribute('data-target');
                const content = document.getElementById(contentId);
                const icon = this.querySelector('.accordion-icon');
                const badge = this.querySelector('.accordion-badge');
                
                if (!content) return;
                
                const isOpen = !content.classList.contains('hidden');
                
                if (isOpen) {
                    content.classList.add('hidden');
                    if (icon) icon.style.transform = 'rotate(0deg)';
                    if (badge) {
                        badge.textContent = '열기';
                        badge.className = 'accordion-badge text-xs font-bold text-gray-500 bg-gray-200 px-3 py-1 rounded-full';
                    }
                } else {
                    content.classList.remove('hidden');
                    if (icon) icon.style.transform = 'rotate(180deg)';
                    if (badge) {
                        badge.textContent = '닫기';
                        badge.className = 'accordion-badge text-xs font-bold text-blue-700 bg-blue-100 px-3 py-1 rounded-full';
                    }
                }
            });
        });


        // ===== 위로가기 버튼 =====
        const scrollToTopBtn = document.getElementById('scroll-to-top');
        window.addEventListener('scroll', () => {
            if (window.scrollY > 300) {
                scrollToTopBtn.classList.remove('opacity-0', 'invisible');
                scrollToTopBtn.classList.add('opacity-100', 'visible');
            } else {
                scrollToTopBtn.classList.add('opacity-0', 'invisible');
                scrollToTopBtn.classList.remove('opacity-100', 'visible');
            }
        });

        // ===== 이벤트 바인딩 (인라인 onclick 대체) =====
        // 히어로 수동 점
        heroDots.forEach((dot, i) => dot.addEventListener('click', () => manualSwitchHero(i)));
        // 요금 탭 전환 (서비스 카드 링크 + 탭 버튼)
        document.querySelectorAll('[data-fee-tab]').forEach(el =>
            el.addEventListener('click', () => switchFeeTab(el.dataset.feeTab))
        );
        // 갤러리 점
        galleryDots.forEach((dot, i) => dot.addEventListener('click', () => goToPhotoSlide(i)));
        // 갤러리 좌우 화살표
        const galleryNavBtns = document.querySelectorAll('.gallery-nav button');
        if (galleryNavBtns[0]) galleryNavBtns[0].addEventListener('click', prevPhotoSlide);
        if (galleryNavBtns[1]) galleryNavBtns[1].addEventListener('click', nextPhotoSlide);
        // 위로가기
        if (scrollToTopBtn) scrollToTopBtn.addEventListener('click', () => window.scrollTo({top:0, behavior:'smooth'}));
    </script>